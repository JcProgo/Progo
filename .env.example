# Copia este archivo a ".env" y completa con los valores de tu proyecto
# Supabase: Project Settings -> API
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-public-key

# Wompi: comercios.wompi.co -> Desarrolladores (llave pública, segura de exponer en frontend)
VITE_WOMPI_PUBLIC_KEY=pub_test_...
VITE_WOMPI_BASE_URL=https://sandbox.wompi.co
